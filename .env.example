# notebooklm-mcp â€” container environment
# Loaded by docker-compose.yml (env_file). Not committed to git â€” add
# this filename to .gitignore if this directory is a repo.

NODE_ENV=production
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Browser automation
HEADLESS=true
STEALTH_ENABLED=true

# Must match the display language of the Google account you'll log in
# with in noVNC (selectors are language-specific). en or fr.
NOTEBOOKLM_UI_LOCALE=en

# Concurrent browser sessions / idle timeout (seconds)
MAX_SESSIONS=10
SESSION_TIMEOUT=900
